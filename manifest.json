{
  "manifest_version": 3,
  "name": "YouTube Focus",
  "version": "1.0",
  "description": "Blocks the YouTube recommendation feed and stops autoplay.",
  "permissions": ["storage"],
  "host_permissions": ["*://*.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["hide.css"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "YouTube Focus"
  },
  "browser_specific_settings": {
    "safari": {
      "strict_min_version": "16.0"
    }
  }
}
